# LLM Provider — choose one: ollama | openrouter | openai
# Default: ollama (local, no API key needed)
LLM_PROVIDER=ollama

# Ollama (local — requires a running Ollama instance at http://localhost:11434)
# Pull a model first:  ollama pull llama3
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter (https://openrouter.ai — get a key from your account settings)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# OpenAI (https://platform.openai.com — create an API key in your dashboard)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
